// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  IN_PROGRESS
  PRESENT
  ABSENT
}

enum FeePaymentStatus {
  PAID
  UNPAID
}

enum StudentAttendanceStatus {
  PRESENT
  ABSENT
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String         @unique
  password      String
  role          Role           @default(TEACHER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  studentDetail       StudentDetail?
  teacherDetail       TeacherDetail?
  adminDetail         AdminDetail?
  parentDetail        ParentDetail?
  notificationsCreated     Notification[]      @relation("NotificationsCreated")
  notificationReads        NotificationRead[]
  feePaymentsUpdated       StudentFeePayment[]
  studentAttendancesMarked StudentAttendance[]

  @@index([role])
}

model Class {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  className  String   @unique
  teacherId  String   @db.ObjectId
  monthlyFee Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  teacher  TeacherDetail   @relation(fields: [teacherId], references: [id])
  students StudentDetail[]

  @@index([teacherId])
}

model StudentDetail {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  studentRollNumber   String    @unique
  userId              String    @unique @db.ObjectId
  classId             String    @db.ObjectId
  parentIds           String[]  @db.ObjectId
  admissionDate       DateTime?
  motherName          String?
  fatherName          String?
  studentAadharNumber String?
  fatherAadharNumber  String?
  motherAadharNumber  String?
  dateOfBirth         DateTime?
  whatsappNumber      String?
  contactNumber1      String?
  contactNumber2      String?
  isStudying          Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  class        Class               @relation(fields: [classId], references: [id])
  parents      ParentDetail[]      @relation(fields: [parentIds], references: [id])
  feePayments  StudentFeePayment[]
  attendances  StudentAttendance[]

  @@index([classId])
}

model StudentAttendance {
  id         String                  @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String                  @db.ObjectId
  date       String
  status     StudentAttendanceStatus
  markedById String?                 @db.ObjectId
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  student  StudentDetail @relation(fields: [studentId], references: [id])
  markedBy User?         @relation(fields: [markedById], references: [id])

  @@unique([studentId, date])
  @@index([date])
  @@index([studentId])
}

model StudentFeePayment {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId          String           @db.ObjectId
  financialYearStart Int
  month              Int
  status             FeePaymentStatus @default(UNPAID)
  amount             Float            @default(0)
  updatedById        String?          @db.ObjectId
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  student   StudentDetail @relation(fields: [studentId], references: [id])
  updatedBy User?         @relation(fields: [updatedById], references: [id])

  @@unique([studentId, financialYearStart, month])
  @@index([financialYearStart, month])
  @@index([studentId])
}

model TeacherDetail {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId           String?  @unique
  phone                String?
  workStartTime        String   @default("09:00")
  workEndTime          String   @default("17:00")
  halfDayThresholdTime String   @default("11:00")
  monthlySalary        Float    @default(0)
  userId               String   @unique @db.ObjectId
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  classes      Class[]
  attendances  TeacherAttendance[]
}

model TeacherAttendance {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  teacherId String           @db.ObjectId
  date      String
  status    AttendanceStatus
  punchIn   DateTime?
  punchOut  DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  teacher TeacherDetail @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, date])
  @@index([date])
  @@index([teacherId])
}

model Holiday {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminDetail {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  designation String?
  userId      String   @unique @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ParentDetail {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  phone       String?
  address     String?
  userId      String   @unique @db.ObjectId
  childrenIds String[] @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  children StudentDetail[] @relation(fields: [childrenIds], references: [id])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  body      String
  createdBy String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User               @relation("NotificationsCreated", fields: [createdBy], references: [id])
  reads  NotificationRead[]

  @@index([createdAt])
}

model NotificationRead {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  notificationId String   @db.ObjectId
  userId         String   @db.ObjectId
  readAt         DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
  @@index([userId])
}
